# Ignore only the specific .dmg file
electron-app/dist/rays-llm-electron-1.0.0-arm64.dmg
# Ignore Electron build outputs and installers
electron-app/dist/
electron-app/*.dmg
electron-app/*.app

# Ignore backend build outputs
backend/dist/
backend/build/

# Ignore frontend build outputs
frontend/dist/
frontend/build/

# Ignore node_modules and Python venv
frontend/node_modules/
backend/venv/

# Ignore other large files
*.dmg
*.app
*.exe
*.zip
